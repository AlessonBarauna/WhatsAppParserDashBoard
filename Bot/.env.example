# Backend API URL
API_URL=http://localhost:5031/api/messages

# Comma-separated list of WhatsApp group names to monitor.
# Messages from these groups are forwarded to the API WITHOUT keyword filtering.
# Example: SUPPLIER_GROUPS=Fornecedores Celular,Atacado Phones,Grupo Revenda
SUPPLIER_GROUPS=

# When no groups are configured (or as fallback for non-group chats),
# filter messages by these keywords (case-insensitive).
# Default covers common phone brands.
KEYWORD_FILTER=IPHONE,XIAOMI,POCO,REDMI,SAMSUNG,MOTOROLA

# Set to true to also log messages that were ignored (noisy, useful for debugging)
LOG_IGNORED=false
